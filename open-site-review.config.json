{
  "scanMode": "files",
  "targets": "defaults, not ie <= 11",
  "paths": [
    "**/*.{html,htm,css,js,mjs,cjs}"
  ],
  "urls": [],
  "includeLinkedAssets": true,
  "sameOriginOnly": true,
  "audienceWeights": null,
  "ignore": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".git/**"
  ],
  "unsupportedThresholdPercent": 10,
  "removableThresholdPercent": 5,
  "format": "markdown",
  "ci": false
}
