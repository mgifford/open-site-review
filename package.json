{
  "name": "open-site-review",
  "version": "0.2.0",
  "description": "Analyze front-end code for compatibility, obsolete polyfills, and modern best-practice adoption opportunities.",
  "main": "src/cli.js",
  "bin": {
    "open-site-review": "src/cli.js"
  },
  "scripts": {
    "scan": "node src/cli.js",
    "scan:example": "node src/cli.js --paths \"examples/**/*.{html,css,js}\" --format markdown",
    "scan:url": "node src/cli.js --urls \"https://example.com\" --format markdown",
    "scan:issue": "node src/cli.js --issue \"mgifford/open-site-review#1\" --format markdown",
    "scan:ci": "node src/cli.js --format github --ci"
  },
  "dependencies": {
    "@mdn/browser-compat-data": "^5.6.26",
    "browserslist": "^4.25.4",
    "caniuse-api": "^3.0.0",
    "fast-glob": "^3.3.3"
  }
}
